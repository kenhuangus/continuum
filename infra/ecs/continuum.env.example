# Copy to /etc/continuum.env on the ECS instance (chmod 600).
# Never commit the real file with secrets.

DASHSCOPE_API_KEY=
QWEN_API_KEY=
CONTINUUM_DB_PATH=/app/data/continuum.db
CONTINUUM_AUTH_DISABLED=1
# CONTINUUM_API_KEYS=demo_key_for_judges
# CONTINUUM_CORS_ORIGINS=http://YOUR_PUBLIC_IP:8000
QWEN_MODEL=qwen-flash
QWEN_EMBED_MODEL=text-embedding-v3
