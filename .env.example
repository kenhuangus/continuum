DASHSCOPE_API_KEY=
QWEN_API_KEY=
QWEN_MODEL=qwen-flash
QWEN_EMBED_MODEL=text-embedding-v3
CONTINUUM_DB_PATH=data/continuum.db
# Comma-separated API keys. When set, requests need X-API-Key or Authorization: Bearer.
CONTINUUM_API_KEYS=
# Force auth off for local demo (also off when CONTINUUM_API_KEYS is empty).
CONTINUUM_AUTH_DISABLED=1
CONTINUUM_RATE_LIMIT_RPM=60
# Optional Postgres URL (interface ready; SQLite is the supported path).
# DATABASE_URL=postgresql://user:pass@localhost/continuum
# CONTINUUM_HITL_FORGET=0
